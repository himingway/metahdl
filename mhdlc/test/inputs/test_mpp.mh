// ============================================================================
// test_mpp.mh - MPP Preprocessor Input Test
// ============================================================================
// MPP Grammar features tested (per mpp.y):
//
// `define MACROS (lines 250-254):
//   - Simple object macro: `define ID verbatims
//   - Function macro with params: `define ID(arg_list) body
//   - Macro with optional/va args: `define ID(a, b, ...) body
//
// `ifdef/`else/`endif (lines 232-242):
//   - `ifdef PURE_ID balanced_block `endif
//   - `ifdef PURE_ID balanced_block `else balanced_block `endif
//   - `ifndef PURE_ID balanced_block `endif
//   - `ifndef PURE_ID balanced_block `else balanced_block `endif
//
// `for LOOP (line 204):
//   - `for (statements; expression; statements) balanced_block `endfor
//   - statements: (comma-separated: statement = ID "++" | ID "--" | ID "=" expr)
//
// `foreach LOOP (line 211):
//   - `foreach ID (foreach_val_list) balanced_block `endfor
//
// ARITHMETIC FUNCTION CALLS:
//   - single_arg: `log2, `floor, `ceil, `abs, `even, `odd (lines 338-344)
//   - two_arg: `hex, `dec, `bin (lines 356-359)
//   - multi_arg: `max, `min (lines 367-369)
//
// EXPRESSIONS (lines 377-406):
//   - Binary: +, -, *, /, %, <<, >>
//   - Conditional: ||, &&, ==, !=, <, >, <=, >=
//   - Unary: ~, !, |, &, ^
//   - Ternary: ? :
//   - Constants: NUM, BIN_BASED_NUM, DEC_BASED_NUM, HEX_BASED_NUM
//   - Parenthesized expressions
//
// `switch / `case / `endswitch (lines 416-428):
//   - `switch (expression) case_list opt_default `endswitch
//
// `let STATEMENT (line 282):
//   - `let statement (ID "++" | ID "--" | ID "=" expression)
//
// Self-increment/decrement (lines 409-411):
//   - ID "++", ID "--", ID "=" expression
// ============================================================================

// ============================================================================
// 1. `define macros
// ============================================================================

// Simple object macro
`define DATA_WIDTH 32

// Object macro with text
`define ENABLE_CLK clk_en

// Function macro with parameters
`define ADD(a, b) ((a) + (b))
`define MUL(x, y) ((x) * (y))

// Macro with optional/va args
`define LOG(msg, level) $display("log: ", msg)
`define VAR_ARGS(first, second, ...) __VA_ARGS__

// ============================================================================
// 2. `ifdef / `else / `endif
// ============================================================================

`ifdef DEBUG
`define SIMULATION "active"
`define DBG_WIDTH 64
`endif

`ifdef PRODUCTION
`define OPTIMIZED 1
`else
`define OPTIMIZED 0
`endif

`ifndef RELEASE
`define TEST_MODE 1
`endif

`ifndef FINAL
`define VERBOSE_LOG 1
`else
`define SILENT 1
`endif

// ============================================================================
// 3. `for loop
// ============================================================================

// Simple for loop
`for (i = 0; i < DATA_WIDTH; i = i + 1)
port_`i
`endfor

// For loop with compound statements
`for (idx = 1, step = 2; idx < 16; idx = idx + step)
wire line_`idx;
`endfor

// For loop with auto increment
`for (n = 0; n < 4; n ++)
reg stage_`n;
`endfor

// ============================================================================
// 4. `foreach loop
// ============================================================================

`foreach TYPE (byte, word, dword)
module TYPE``_unit;
endmodule
`endfor

// ============================================================================
// 5. Arithmetic function calls
// ============================================================================

// Single-arg functions
`define HALF_WIDTH `log2(16)
`define ROUNDED_V `floor(4.9)
`define CEILED_V `ceil(4.1)
`define ABS_V `abs(-42)
`define IS_EVEN `even(8)
`define IS_ODD `odd(7)

// Two-arg functions
`define HEX_VAL `hex(255)
`define DEC_VAL `dec(100)
`define BIN_VAL `bin(15)

// Multi-arg functions
`define BIGGEST `max(10, 20, 30)
`define SMALLEST `min(5, 15, 25)

// Functions in expressions
`let expr_val = `log2(256) + `max(32, 64)
`let calc_result = (`abs(-5) * 2) + `floor(7.8)

// ============================================================================
// 6. `let statements (ID = expression)
// ============================================================================

`let base = 10
`let offset = 5
`let total = base + offset
`let product = base * 4
`let shift_result = 64 >> 3

// Self-increment
`let counter = 0
counter ++
counter --

// With expressions
`let mask = (1 << 8) - 1
`let tern = (total > 10) ? 1 : 0

// ============================================================================
// 7. Expressions
// ============================================================================

// Binary operators
`let add_v = 10 + 20
`let sub_v = 100 - 50
`let mul_v = 8 * 4
`let div_v = 64 / 8
`let mod_v = 17 % 5
`let shl_v = 1 << 4
`let shr_v = 256 >> 4

// Logical operators
`let and_v = 0xFF & 0x0F
`let or_v = 0xF0 | 0x0F
`let xor_v = 0xAA ^ 0x55

// Comparison
`let cmp = (10 < 20) && (30 > 15)
`let eql = (42 == 42) || (0 != 1)

// Unary operators
`let neg = ~0xFF
`let lnot = !(0)
`let band = &0xF
`let bor = |0xF

// Ternary
`let result = (10 > 5) ? 100 : 0

// ============================================================================
// 8. `switch / `case / `endswitch
// ============================================================================

`switch (DATA_WIDTH)
`case 8
wire byte_bus;
`case 16, 32
wire wide_bus;
`default
wire generic_bus;
`endswitch

// ============================================================================
// 9. Constants
// ============================================================================

`let plain_num = 42
`define PLAIN_CONST 100

// ============================================================================
// 10. Line directive
// ============================================================================

`line 200 "generated_source.mh"
