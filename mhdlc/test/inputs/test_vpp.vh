// test_vpp.vh - VPP Preprocessor Input Test
// Tests VPP features that can actually pass through the VPP pipeline.
// After VPP preprocessing, this must be valid SystemVerilog.

`define WIDTH 32

module test_vpp;

// ============================================================================
// 1. `ifdef / `ifndef / `else / `endif
// ============================================================================
`ifdef DEBUG
parameter SIM_LEVEL = 5;
`endif

`ifndef RELEASE
parameter DEBUG_FLAG = 1;
`else
parameter RELEASE_FLAG = 1;
`endif

// ============================================================================
// 2. `if conditionals (simple expressions only)
// ============================================================================
`if WIDTH > 16
parameter EXTENDED = 1;
`else
parameter EXTENDED = 0;
`endif

// ============================================================================
// 3. `let assignments
// ============================================================================
`let counter = 0
`let threshold = 128
`let half_width = WIDTH / 2

// ============================================================================
// 4. Binary arithmetic
// ============================================================================
`let sum_val = 10 + 20
`let diff_val = 100 - 50
`let prod_val = 8 * 4
`let div_val = 64 / 8
`let mod_val = 17 % 5

// ============================================================================
// 5. Shift and power
// ============================================================================
`let shift_left = 1 << 4
`let shift_right = 256 >> 4

// ============================================================================
// 6. Comparison
// ============================================================================
`if 42 == 42
parameter EQ_OK = 1;
`endif

`if 0 != 1
parameter NE_OK = 1;
`endif

// ============================================================================
// 7. Bitwise
// ============================================================================
`let bw_or = 240 | 15
`let bw_xor = 170 ^ 85

// ============================================================================
// 8. Unary
// ============================================================================
`let neg_val = ~255
`let lnot_val = !(0)

// ============================================================================
// 9. Parenthesized
// ============================================================================
`let grouped = ((1 + 2) * 3) - 4
`let complex = 100 / 10 + 3 * 4 - 2

// ============================================================================
// 10. Built-in math functions
// ============================================================================
`let log2_val = LOG2(256)
`let round_val = ROUND(3.7)
`let ceil_val = CEIL(4.1)
`let floor_val = FLOOR(4.9)
`let abs_val = ABS(-99)
`let even_val = EVEN(8)
`let odd_val = ODD(7)
`let max_val = MAX(42, 100)
`let min_val = MIN(42, 100)

// ============================================================================
// 11. `for loop
// ============================================================================
`for (i = 0; i < 8; i = i + 1)
wire bit_`i;
`endfor

// ============================================================================
// 12. `while loop
// ============================================================================
`let j = 0
`while (j < 4)
wire loop_`j;
`let j = j + 1
`endwhile

// ============================================================================
// 13. `switch / `case / `endswitch
// ============================================================================
`switch half_width
`case 8
parameter BYTE_TYPE = 1;
`case 16
parameter WORD_TYPE = 1;
`default
parameter GENERIC_TYPE = 1;
`endswitch

// ============================================================================
// 14. `breaksw
// ============================================================================
`switch half_width
`case 4
parameter SHORT_VAL = 1;
`breaksw
`case 8
parameter WIDE_VAL = 1;
`breaksw
`endswitch

// ============================================================================
// 15. Primary types
// ============================================================================
`let filename = "test_file.txt"
`let pi = 3.14159
`let plain = 42

endmodule
